{
  "multipart": [
    {
      "apply": { "model": "chaosmod:enderite_forge_walls_core" }
    },
    {
      "when": { "north": "true" },
      "apply": { "model": "chaosmod:enderite_forge_walls_side", "uvlock": true }
    },
    {
      "when": { "south": "true" },
      "apply": { "model": "chaosmod:enderite_forge_walls_side", "y": 180, "uvlock": true }
    },
    {
      "when": { "west": "true" },
      "apply": { "model": "chaosmod:enderite_forge_walls_side", "y": 270, "uvlock": true }
    },
    {
      "when": { "east": "true" },
      "apply": { "model": "chaosmod:enderite_forge_walls_side", "y": 90, "uvlock": true }
    },
    {
      "when": { "up": "true" },
      "apply": { "model": "chaosmod:enderite_forge_walls_side", "x": -90, "uvlock": true }
    },
    {
      "when": { "down": "true" },
      "apply": { "model": "chaosmod:enderite_forge_walls_side", "x": 90, "uvlock": true }
    }
  ]
}